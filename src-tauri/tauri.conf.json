{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noteo",
  "version": "2.0.0",
  "identifier": "com.noteo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Noteo",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; connect-src 'self' https://*.supabase.co wss://*.supabase.co; img-src 'self' data: blob:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Noteo",
    "copyright": "© 2026 Noteo. Tous droits réservés.",
    "category": "Education",
    "shortDescription": "Suivi académique personnel",
    "longDescription": "Noteo est une application de bureau permettant aux étudiants de gérer leurs notes, suivre leur progression académique et visualiser leurs résultats par matière.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
